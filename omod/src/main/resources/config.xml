<?xml version="1.0" encoding="UTF-8"?>

<module configVersion="1.2">

	<!-- Module Properties -->
	<id>${project.parent.artifactId}</id>
	<name>${project.parent.name}</name>
	<version>${project.parent.version}</version>
	<package>org.openmrs.module.chartsearchai</package>
	<author>OpenMRS</author>
	<description>${project.parent.description}</description>
	<updateURL>https://modules.openmrs.org/modules/download/${project.parent.artifactId}/update.rdf</updateURL>
	<require_version>${openmrsPlatformVersion}</require_version>

	<require_modules>
		<require_module version="2.44.0">org.openmrs.module.webservices.rest</require_module>
	</require_modules>

	<!-- Module Activator -->
	<activator>org.openmrs.module.chartsearchai.ChartSearchAiModuleActivator</activator>

	<!-- Hibernate Mappings -->
	<mappingFiles>
		ChartEmbedding.hbm.xml
		ChartSearchAuditLog.hbm.xml
	</mappingFiles>

	<!-- Privileges -->
	<privilege>
		<name>AI Query Patient Data</name>
		<description>Allows querying patient charts using the AI-powered chart search</description>
	</privilege>

	<privilege>
		<name>View AI Audit Logs</name>
		<description>Allows viewing the audit log of AI chart search queries</description>
	</privilege>

	<!-- Global Properties -->
	<globalProperty>
		<property>chartsearchai.searchMode</property>
		<defaultValue>llm</defaultValue>
		<description>Search mode: "llm" sends the full patient chart to the LLM for direct inference. "embedding" uses vector similarity to retrieve relevant records before sending them to the LLM.</description>
	</globalProperty>

	<globalProperty>
		<property>chartsearchai.llm.modelPath</property>
		<defaultValue></defaultValue>
		<description>Path to the GGUF LLM model file (e.g. Llama 3.2 3B). Required for both search modes.</description>
	</globalProperty>

	<globalProperty>
		<property>chartsearchai.embedding.provider</property>
		<defaultValue>term-frequency</defaultValue>
		<description>Embedding provider for the embedding search mode: "term-frequency" (default hash-based vectors) or "onnx" (semantic vectors via all-MiniLM-L6-v2).</description>
	</globalProperty>

	<globalProperty>
		<property>chartsearchai.embedding.modelPath</property>
		<defaultValue></defaultValue>
		<description>Path to the ONNX embedding model file. Required when embedding provider is set to "onnx".</description>
	</globalProperty>

	<!-- AOP -->
	<advice>
		<point>org.openmrs.api.EncounterService</point>
		<class>org.openmrs.module.chartsearchai.api.EncounterIndexingAdvice</class>
	</advice>

	<advice>
		<point>org.openmrs.api.ConditionService</point>
		<class>org.openmrs.module.chartsearchai.api.PatientDataIndexingAdvice</class>
	</advice>

	<advice>
		<point>org.openmrs.api.PatientService</point>
		<class>org.openmrs.module.chartsearchai.api.PatientDataIndexingAdvice</class>
	</advice>

	<advice>
		<point>org.openmrs.api.OrderService</point>
		<class>org.openmrs.module.chartsearchai.api.PatientDataIndexingAdvice</class>
	</advice>

	<!-- Internationalization -->
	<messages>
		<lang>en</lang>
		<file>messages.properties</file>
	</messages>

</module>
